{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Skill(*)",
      "mcp__*__*"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(eval:*)",
      "NotebookEdit"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/mcp/serena-wrapper.sh start"
          },
          {
            "type": "command",
            "command": "echo '{\"session_id\":\"'$(uuidgen)'\"}' | cmux claude-hook session-start 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/on-clear.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          },
          {
            "type": "command",
            "command": "osascript -e \"display notification \\\"$(basename $(git rev-parse --show-toplevel 2>/dev/null) 2>/dev/null || echo 'unknown') / $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')\\\" with title \\\"入力待ち\\\" sound name \\\"Funk\\\"\""
          },
          {
            "type": "command",
            "command": "echo '{}' | cmux claude-hook notification 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          },
          {
            "type": "command",
            "command": "osascript -e \"display notification \\\"$(basename $(git rev-parse --show-toplevel 2>/dev/null) 2>/dev/null || echo 'unknown') / $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')\\\" with title \\\"タスク完了\\\" sound name \\\"Glass\\\"\""
          },
          {
            "type": "command",
            "command": "echo '{}' | cmux claude-hook stop 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline.js"
  },
  "skipDangerousModePermissionPrompt": true
}
