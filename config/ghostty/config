# Ghostty Configuration
# https://ghostty.org/docs/config
# シンプル構成: tmuxは必要な時だけ手動起動

# ===== Local Override (machine-specific, not tracked in git) =====
config-file = ?local.conf

# ===== Theme =====
theme = "TokyoNight Night"

# ===== Font =====
font-family = "Hack Nerd Font Mono"
font-family = "PlemolJP Console"
font-size = 16
font-thicken = true

# ===== Background =====
background-image = ghostty_background.png
background-image-opacity = 0.9
background-image-fit = cover
background-opacity = 0.5
background-blur = true

# ===== Window =====
macos-titlebar-style = tabs
window-save-state = always

# ===== Cursor =====
cursor-style = block
cursor-style-blink = true

# ===== Keybinds =====
# フルスクリーン
keybind = super+shift+enter=toggle_fullscreen

# Claude Code用改行
keybind = alt+enter=text:\n

# ペイン削除
keybind = cmd+shift+w=close_surface

# lazygit起動（現在のペインで）
keybind = cmd+g=text:lazygit\x0d

# ペイン移動 (Ctrl+Shift+hjkl)
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right
